{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Remote Debug (Docker in Vagrant)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/project",
                    "remoteRoot": "/app"
                }
            ],
            "django": true,
            "justMyCode": true,
            "restart": true
        },
        {
            "name": "Django: Local Debug (直接在 VM 跑)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/project/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "justMyCode": true
        }
    ]
}